{# Promo Bar Module Template - Frontend #}
<div class="promo-bar-container" id="promoBarContainer">
    <div class="promo-bar" style="background-color: {{ bg_color }}; color: {{ text_color }};">
        {% if link and clickable %}
        <a href="{{ link }}" class="promo-bar-link" style="color: {{ text_color }}; text-decoration: none; display: block;">
        {% endif %}
        
        <div class="promo-bar-content">
            <div class="promo-bar-track" id="promoBarTrack">
                <span class="promo-bar-text">{{ text }}</span>
                {% if duplicate %}
                <span class="promo-bar-text promo-bar-spacer">⚡</span>
                <span class="promo-bar-text">{{ text }}</span>
                {% endif %}
            </div>
        </div>
        
        {% if link and clickable %}
        </a>
        {% endif %}
    </div>
</div>

<style>
.promo-bar-container {
    width: 100%;
    overflow: hidden;
    position: relative;
    z-index: 9999;
}

.promo-bar {
    width: 100%;
    padding: 10px 0;
    font-size: 14px;
    font-weight: 500;
    text-align: center;
    box-sizing: border-box;
}

.promo-bar-link {
    display: block;
    width: 100%;
    height: 100%;
}

.promo-bar-content {
    overflow: hidden;
    white-space: nowrap;
    position: relative;
}

.promo-bar-track {
    display: inline-block;
    white-space: nowrap;
    animation: promo-scroll linear infinite;
    animation-duration: {{ speed }}s;
}

.promo-bar-text {
    display: inline-block;
    padding: 0 30px;
}

.promo-bar-spacer {
    padding: 0 50px;
}

@keyframes promo-scroll {
    0% {
        transform: translateX(0);
    }
    100% {
        transform: translateX(-50%);
    }
}

/* Mobile responsive */
@media (max-width: 768px) {
    .promo-bar {
        font-size: 12px;
        padding: 8px 0;
    }
    
    .promo-bar-text {
        padding: 0 20px;
    }
}

@media (max-width: 480px) {
    .promo-bar {
        font-size: 11px;
        padding: 6px 0;
    }
    
    .promo-bar-text {
        padding: 0 15px;
    }
}

/* Hover effect for clickable bar */
.promo-bar-link:hover {
    opacity: 0.9;
}

/* Ensure smooth rendering */
.promo-bar-track {
    will-change: transform;
    backface-visibility: hidden;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    var track = document.getElementById('promoBarTrack');
    if (!track) return;
    
    // Ensure seamless loop by resetting animation
    track.addEventListener('animationiteration', function() {
        // Animation naturally loops via CSS
    });
    
    // Pause on hover (optional - can be removed if not needed)
    var promoBar = document.querySelector('.promo-bar');
    if (promoBar) {
        promoBar.addEventListener('mouseenter', function() {
            track.style.animationPlayState = 'paused';
        });
        
        promoBar.addEventListener('mouseleave', function() {
            track.style.animationPlayState = 'running';
        });
    }
});
</script>
